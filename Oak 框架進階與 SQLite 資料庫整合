## 四、完整留言板系統 (blog-memory)

### 4.1 系統架構

```
blog-memory/
├── app.js       # 主程式(路由定義)
└── render.js    # 視圖模板(HTML 生成)
```

### 4.2 app.js 主程式

```javascript
import { Application, Router } from "https://deno.land/x/oak/mod.ts";
import * as render from './render.js';

const app = new Application();
const router = new Router();

// 資料存儲(記憶體版本)
const posts = [
    { id: 0, title: "第一篇文章", body: "這是第一篇文章的內容" },
    { id: 1, title: "第二篇文章", body: "這是第二篇文章的內容" }
];

// 1. 列出所有文章
router.get("/", (ctx) => {
    ctx.response.body = render.list(posts);
});

// 2. 顯示新增文章表單
router.get("/post/new", (ctx) => {
    ctx.response.body = render.newPost();
});

// 3. 顯示單一文章
router.get("/post/:id", (ctx) => {
    const id = parseInt(ctx.params.id);
    const post = posts[id];
    if (post) {
        ctx.response.body = render.show(post);
    } else {
        ctx.response.status = 404;
        ctx.response.body = "文章不存在";
    }
});

// 4. 創建新文章(處理表單提交)
router.post("/post", async (ctx) => {
    // 取得請求主體
    const body = await ctx.request.body();
  
    // 檢查是否為表單資料
    if (body.type === "form") {
        const pairs = await body.value;
        const post = {};
      
        // 將表單資料轉換為物件
        for (const [key, value] of pairs) {
            post[key] = value;
        }
      
        console.log("post=", post);
      
        // 設定文章 ID 和時間
        const id = posts.length;
        post.created_at = new Date();
        post.id = id;
      
        // 加入陣列
        posts.push(post);
      
        // 重新導向到首頁
        ctx.response.redirect("/");
    }
});

// 啟用路由
app.use(router.routes());
app.use(router.allowedMethods());

console.log("伺服器啟動於 http://127.0.0.1:8000");
await app.listen({ port: 8000 });
```

