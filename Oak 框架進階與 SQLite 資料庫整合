        "SELECT id, title, body, created_at FROM posts ORDER BY id DESC"
    );
  
    // 將查詢結果轉換為物件陣列
    const posts = rows.map(([id, title, body, created_at]) => ({
        id, title, body, created_at
    }));
  
    ctx.response.body = render.list(posts);
});

// 顯示新增表單
router.get("/post/new", (ctx) => {
    ctx.response.body = render.newPost();
});

// 顯示單一文章
router.get("/post/:id", (ctx) => {
    const id = ctx.params.id;
    const rows = db.query(
        "SELECT id, title, body, created_at FROM posts WHERE id = ?",
        [id]
    );
  
    if (rows.length > 0) {
        const [id, title, body, created_at] = rows[0];
        ctx.response.body = render.show({ id, title, body, created_at });
    } else {
        ctx.response.status = 404;
        ctx.response.body = "文章不存在";
    }
});

// 創建新文章
router.post("/post", async (ctx) => {
    const body = await ctx.request.body();
  
    if (body.type === "form") {
        const pairs = await body.value;
        const post = {};
      
        for (const [key, value] of pairs) {
            post[key] = value;
        }
      
        // 插入資料庫
        db.query(
            "INSERT INTO posts (title, body) VALUES (?, ?)",
            [post.title, post.body]
        );
      
        ctx.response.redirect("/");
    }
});

app.use(router.routes());
app.use(router.allowedMethods());

await app.listen({ port: 8000 });
```

**render.js 需要修改的地方**:
```javascript
// 顯示文章時加上時間
export function show(post) {
    return layout(post.title, `
        <h2>${post.title}</h2>
        <p style="color: #666;">發表於: ${post.created_at}</p>
        <pre>${post.body}</pre>
        <p><a href="/">返回列表</a></p>
    `);
}
```

