    `;
}

// 列出所有文章
export function list(posts) {
    let content = `
        <p>目前有 ${posts.length} 則貼文</p>
        <p><a href="/post/new">創建新貼文</a></p>
    `;
  
    for (const post of posts) {
        content += `
        <div class="post">
            <h2><a href="/post/${post.id}">${post.title}</a></h2>
            <p>${post.body.substring(0, 100)}...</p>
        </div>
        `;
    }
  
    return layout("部落格", content);
}

// 新增文章表單
export function newPost() {
    return layout("新增文章", `
        <form action="/post" method="POST">
            <p>
                <label>標題:</label><br>
                <input type="text" name="title" required>
            </p>
            <p>
                <label>內容:</label><br>
                <textarea name="body" rows="10" required></textarea>
            </p>
            <p>
                <button type="submit">送出</button>
            </p>
        </form>
    `);
}

// 顯示單一文章
export function show(post) {
    return layout(post.title, `
        <h2>${post.title}</h2>
        <pre>${post.body}</pre>
        <p><a href="/">返回列表</a></p>
    `);
}
```

### 4.4 重要概念解析

#### 表單處理流程

```javascript
// HTML 表單
<form action="/post" method="POST">
    <input type="text" name="title">
    <textarea name="body"></textarea>
    <button type="submit">送出</button>
</form>

// 伺服器端接收
router.post("/post", async (ctx) => {
    const body = await ctx.request.body();
  
    if (body.type === "form") {
        const pairs = await body.value;  // FormData 的鍵值對
      
        const post = {};
        for (const [key, value] of pairs) {
            post[key] = value;
        }
      
        // post = { title: "...", body: "..." }
    }
});
```

#### `<pre>` 標籤的用途

```html
<!-- 一般 <div>:換行會被忽略 -->
<div>
第一行
第二行
第三行
</div>
<!-- 顯示結果: 第一行 第二行 第三行 (在同一行) -->

<!-- <pre>:保留原始格式 -->
<pre>
第一行
第二行
第三行
</pre>
<!-- 顯示結果:
第一行
第二行
第三行
-->
```

#### 重新導向 (Redirect)

```javascript
// 創建文章後導向首頁
ctx.response.redirect("/");

// 相當於瀏覽器訪問 http://localhost:8000/
```

