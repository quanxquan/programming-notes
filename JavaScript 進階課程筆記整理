## 八、重要概念回顧

### 8.1 函數作為參數的優勢

**靈活性**:
```javascript
// 差異示範
// 寫死的版本
function differentiateSquare(x) {
    return 2 * x;
}

// 通用的版本
function differentiate(f, x) {
    let h = 0.0001;
    return (f(x + h) - f(x)) / h;
}

// 可以微分任意函數
console.log(differentiate(x => x * x, 3));      // 平方
console.log(differentiate(x => Math.sin(x), 0)); // 正弦
```

### 8.2 運算符注意事項

#### 相等性判斷

```javascript
// 不嚴格相等(會進行型別轉換)
console.log(1 == "1");   // true

// 嚴格相等(不轉換型別)
console.log(1 === "1");  // false

// 建議使用 === 和 !==
```

#### 其他運算符

```javascript
// 不等於
console.log(1 != 2);   // true
console.log(1 !== "1"); // true(嚴格不等於)

// 三元運算符
let result = (age >= 18) ? "成年" : "未成年";
```

